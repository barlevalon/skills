{
  "name": "manual-release-skill",
  "version": "0.1.2",
  "description": "A universal Agent Skill for AI-assisted manual software releases with evidence-backed changelogs and approval-gated publishing.",
  "license": "MIT",
  "author": "Alon Bar-Lev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barlevalon/manual-release-skill.git"
  },
  "bugs": {
    "url": "https://github.com/barlevalon/manual-release-skill/issues"
  },
  "homepage": "https://github.com/barlevalon/manual-release-skill#readme",
  "keywords": [
    "agent-skill",
    "agent-skills",
    "changelog",
    "claude-code",
    "codex",
    "cursor",
    "manual-release",
    "pi",
    "pi-package",
    "release-management",
    "release-notes",
    "semver",
    "skills"
  ],
  "files": [
    "skills",
    "docs",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "validate": "node scripts/validate-package.mjs",
    "pack:check": "npm pack --dry-run",
    "ci": "npm run validate && npm run pack:check"
  },
  "pi": {
    "skills": [
      "./skills"
    ]
  }
}
