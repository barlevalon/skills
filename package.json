{
  "name": "@barlevalon/skills",
  "version": "0.7.0",
  "description": "A monorepo of portable Agent Skills for AI-assisted engineering workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barlevalon/skills.git"
  },
  "bugs": {
    "url": "https://github.com/barlevalon/skills/issues"
  },
  "homepage": "https://github.com/barlevalon/skills#readme",
  "keywords": [
    "agent-skill",
    "agent-skills",
    "ai-agent",
    "claude-code",
    "codex",
    "cursor",
    "monorepo",
    "pi",
    "pi-package",
    "skills"
  ],
  "bin": {
    "barlevalon-skills": "./bin/barlevalon-skills.mjs"
  },
  "files": [
    "bin",
    "skills",
    "docs",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "skills/*/*"
  ],
  "scripts": {
    "validate": "node scripts/validate-package.mjs",
    "pack:check": "npm pack --dry-run",
    "pack:skills": "npm run pack:check --workspaces --if-present",
    "ci": "npm run validate && npm run pack:check && npm run pack:skills"
  },
  "pi": {
    "skills": [
      "./skills/*/*/SKILL.md"
    ]
  },
  "curator": "Alon Hearter"
}
